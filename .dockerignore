# =============================================================================
# .dockerignore — AlugaFácil
# Lista de arquivos/pastas ignorados no contexto de build do Docker
# Reduz o tamanho do contexto enviado ao Docker daemon (build mais rápido)
# =============================================================================

# ─── Dependências (serão reinstaladas no container) ──────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Build do Next.js (será gerado no container) ─────────────────────────────
.next
out
build
dist

# ─── Variáveis de ambiente (NUNCA incluir no contexto de build) ──────────────
.env
.env.local
.env.development
.env.test
.env.production
.env.prod
*.env

# ─── Git ─────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Docker (evita recursão) ─────────────────────────────────────────────────
Dockerfile*
!Dockerfile        # Re-inclui o Dockerfile (não ignorar)
docker-compose*
.dockerignore

# ─── Documentação e configurações de editor ──────────────────────────────────
README.md
CHANGELOG.md
LICENSE
.editorconfig
.vscode
.idea

# ─── Testes ──────────────────────────────────────────────────────────────────
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage
jest.config.*

# ─── CI/CD ───────────────────────────────────────────────────────────────────
.github
.gitlab-ci.yml

# ─── Sistema operacional ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────────────────────────
logs
*.log

# ─── Cache ───────────────────────────────────────────────────────────────────
.cache
.turbo
.eslintcache